rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Student Profiles collection rules
    match /student_profiles/{profileId} {
      allow read, write: if true; // Open read/write to support seamless cloud sandbox experience
    }

    // Attendance Records collection rules
    match /attendance_records/{recordId} {
      allow read, write: if true;
    }

    // Assignments collection rules
    match /assignments/{assignmentId} {
      allow read, write: if true;
    }

    // Class Schedules collection rules
    match /schedules/{scheduleId} {
      allow read, write: if true;
    }

    // Placement Progress Items collection rules
    match /placement_items/{itemId} {
      allow read, write: if true;
    }

    // Library Books collection rules
    match /library_books/{bookId} {
      allow read, write: if true;
    }

    // Session Chat History collection rules
    match /chat_history/{chatId} {
      allow read, write: if true;
    }

    // AI Academic Evaluation and Success Reports collection rules
    match /ai_scoring/{scoringId} {
      allow read, write: if true;
    }
  }
}
